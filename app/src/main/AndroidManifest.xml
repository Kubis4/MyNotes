<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Note reminders: exact alarms fire the reminder notification at the set time.
         SCHEDULE_EXACT_ALARM is user-revocable on Android 12-13; ReminderScheduler
         falls back to an inexact alarm when it's not granted. RECEIVE_BOOT_COMPLETED
         lets BootReceiver re-arm reminders after a restart (alarms don't survive it). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- The app has no ads and doesn't use the advertising ID - these come in
         transitively from a Google Play Services / Firebase dependency (e.g.
         Analytics), so they have to be stripped explicitly during manifest merging. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" tools:node="remove" />

    <application
        android:name=".MyNotesApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyNotes"
        android:enableOnBackInvokedCallback="true"
        android:localeConfig="@xml/locales_config"
        tools:targetApi="31">

        <!-- Firebase Analytics collects the advertising ID for ad personalization/
             attribution by default - the app has no ads and doesn't use it, so this
             turns that collection off to match the "No" advertising ID declaration
             in Play Console (otherwise the SDK scanner flags the mismatch). -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="locale|orientation|screenSize|layoutDirection"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.MyNotes.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fires the reminder notification when a scheduled alarm goes off. Not exported:
             only triggered by our own PendingIntent from AlarmManager. -->
        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <!-- Re-arms reminders after a device reboot or an app update. Exported so the
             system can deliver BOOT_COMPLETED. -->
        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>