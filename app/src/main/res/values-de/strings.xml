    <string name="about_support_title">MyNotes unterstützen</string>
    <string name="about_support_description">MyNotes ist komplett kostenlos und werbefrei. Wenn dir die App gefällt, kannst du mir ein Bier spendieren — jeder Beitrag ist freiwillig und hilft, dass es so bleibt.</string>
    <string name="about_coffee_button">Spendier mir ein Bier</string>
