    <string name="about_support_title">Podporte SelfNote</string>
    <string name="about_support_description">SelfNote je vyvíjaný s vášňou ako nezávislý projekt. Ak sa vám aplikácia páči a považujete ju za užitočnú, zvážte podporu jej vývoja!</string>
