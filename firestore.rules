rules_version = '2';

// Security rules for MyNotes. Deploy from the Firebase console (Firestore ->
// Rules) or with the CLI: `firebase deploy --only firestore:rules`.
//
// Design notes:
// - Everything requires a signed-in user; there is no anonymous access at all.
// - Notes are only visible to their owner + collaborators, invites only to
//   their sender/recipient, so one user can never enumerate another's data.
// - Writes validate document shape and size, so a hijacked client can't blow
//   up storage/bandwidth by writing megabyte documents in a loop.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    // users/{uid}: profile documents created at sign-in.
    match /users/{userId} {
      // Any signed-in user may read profiles (needed to resolve collaborator
      // display names), but can only create/update their own.
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && (!('displayName' in request.resource.data)
            || request.resource.data.displayName == null
            || request.resource.data.displayName.size() < 200);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    // collaborative_notes/{noteId}: shared notes and checklists.
    match /collaborative_notes/{noteId} {

      function isMember() {
        return resource.data.ownerId == request.auth.uid
          || request.auth.uid in resource.data.collaborators;
      }

      // Content is a JSON string of note lines; cap sizes well below the 1 MiB
      // document limit so bulk-write abuse stays cheap to store and serve.
      function validNoteShape() {
        return request.resource.data.title is string
          && request.resource.data.title.size() < 1000
          && request.resource.data.content is string
          && request.resource.data.content.size() < 500000
          && request.resource.data.collaborators is list
          && request.resource.data.collaborators.size() <= 50;
      }

      allow read: if signedIn() && isMember();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.collaborators
        && validNoteShape();

      // Membership may ONLY change via self-add (invite acceptance) or
      // self-remove (leaving) - nobody, not even the owner, can force another
      // user into a note. This is what guarantees an invitation always needs
      // the recipient's explicit accept, regardless of the client app version.
      allow update: if signedIn() && validNoteShape() && (
        // Normal edits by members: content/title/metadata, but never the
        // membership or ownership fields.
        (
          isMember()
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['collaborators', 'ownerId'])
        )
        // Invite acceptance: a non-member adds exactly themselves.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaborators'])
          && request.resource.data.collaborators.hasAll(resource.data.collaborators)
          && !(request.auth.uid in resource.data.collaborators)
          && request.auth.uid in request.resource.data.collaborators
          && request.resource.data.collaborators.size() == resource.data.collaborators.size() + 1
        )
        // Leaving: a member removes exactly themselves (the app also bumps
        // updatedAt in the same write).
        || (
          isMember()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['collaborators', 'updatedAt'])
          && resource.data.collaborators.hasAll(request.resource.data.collaborators)
          && !(request.auth.uid in request.resource.data.collaborators)
          && request.resource.data.collaborators.size() == resource.data.collaborators.size() - 1
        )
        // Owner leaving a note that still has members: removes themselves and
        // hands ownership to one of the remaining collaborators.
        || (
          resource.data.ownerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['collaborators', 'ownerId', 'updatedAt'])
          && resource.data.collaborators.hasAll(request.resource.data.collaborators)
          && !(request.auth.uid in request.resource.data.collaborators)
          && request.resource.data.collaborators.size() == resource.data.collaborators.size() - 1
          && request.resource.data.ownerId in request.resource.data.collaborators
        )
      );

      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    // note_invites/{inviteId}: pending collaboration invitations.
    match /note_invites/{inviteId} {

      function isSender() {
        return resource.data.senderEmail == userEmail();
      }

      function isRecipient() {
        return resource.data.recipientEmail == userEmail();
      }

      allow read: if signedIn() && (isSender() || isRecipient());

      // Only members of the referenced note may invite others to it, and the
      // sender identity must match the signed-in account.
      allow create: if signedIn()
        && request.resource.data.senderEmail == userEmail()
        && request.resource.data.recipientEmail is string
        && request.resource.data.recipientEmail.size() < 200
        && request.resource.data.noteTitle.size() < 1000
        && (
          get(/databases/$(database)/documents/collaborative_notes/$(request.resource.data.noteId)).data.ownerId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/collaborative_notes/$(request.resource.data.noteId)).data.collaborators
        );

      // Status transitions only (accept/decline/expire) - nobody can rewrite
      // an invite to point at a different note or recipient.
      allow update: if signedIn()
        && (isSender() || isRecipient())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt']);

      allow delete: if signedIn() && (isSender() || isRecipient());
    }

    // Anything not matched above is denied by default.
  }
}
